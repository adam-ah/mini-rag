# Copy to .env and edit. Format is KEY=VALUE, one per line.
# corpus.py loads this at startup; real environment variables take precedence.

# Answer backend: openai | claude | extractive
SEARCH_BACKEND=openai

# --- OpenAI-compatible endpoint (local server, OpenAI, or OpenRouter) ---
# The app POSTs to <OPENAI_BASE_URL>/chat/completions. Keep the /v1 suffix.

# Local server (llama.cpp / LM Studio / Ollama) — no key needed:
OPENAI_BASE_URL=http://localhost:8080/v1
SEARCH_MODEL=local
OPENAI_API_KEY=

# Review every synthesized answer for evidence-grounded gaps. Follow-up retrieval
# and regeneration run only when the review finds a concrete unresolved concept.
SEARCH_ADAPTIVE_REFINEMENT=true
# SEARCH_REFLECTION_MAX_QUERIES=3
# SEARCH_REFLECTION_MAX_TOKENS=400
# SEARCH_REFLECTION_CONTEXT_BUDGET=12000
# SEARCH_REFINEMENT_CONTEXT_BUDGET=10000

# --- Dedicated live-test endpoint ---
# Live tests never use OPENAI_BASE_URL or the endpoint saved in the GUI. Set these
# separately. test.sh defaults to the endpoint and model below.
AI_TEST_BASE_URL=http://10.0.0.10:8080/v1
AI_TEST_MODEL=local
# AI_TEST_API_KEY=
# AI_TEST_TIMEOUT=180
# RUN_LIVE_AI_TESTS=0

# OpenAI:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   SEARCH_MODEL=gpt-4o-mini
#   OPENAI_API_KEY=sk-...

# OpenRouter (OpenAI-compatible; model ids at openrouter.ai/models):
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   SEARCH_MODEL=anthropic/claude-3.5-sonnet
#   OPENAI_API_KEY=sk-or-...

# --- Anthropic (only when SEARCH_BACKEND=claude) ---
# ANTHROPIC_API_KEY=sk-ant-...
# SEARCH_MODEL=claude-opus-4-8

# Web server port
# PORT=5000
